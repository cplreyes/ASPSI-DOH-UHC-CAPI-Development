# Production build env for the F2 PWA (loaded by `vite build` only — NOT by vitest,
# which runs in test mode, so the full multi-language test suite stays green).
#
# TEMPORARY — Shan request 2026-06-16: ship English-only so the team can capture
# clean English screenshots of the survey. Collapses READY_LOCALES to English,
# hiding the language switcher and resetting any persisted dialect to English.
# Applies to BOTH the prod (f2-pwa) and staging (f2-pwa-staging) Pages builds.
# REVERT when screenshots are done: delete this line (or the file) and let CI redeploy.
VITE_ENGLISH_ONLY=true
