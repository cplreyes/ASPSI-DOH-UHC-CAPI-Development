{
  "name": "f2-pwa-worker",
  "private": true,
  "version": "0.1.0",
  "description": "Cloudflare Worker auth proxy in front of the F2 PWA Apps Script backend. See ../../../docs/superpowers/specs/2026-04-26-f2-pwa-auth-rearch-design.md.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "secret:put:jwt": "wrangler secret put JWT_SIGNING_KEY",
    "secret:put:hmac": "wrangler secret put APPS_SCRIPT_HMAC",
    "secret:put:admin": "wrangler secret put ADMIN_PASSWORD_HASH",
    "secret:put:apps-script-url": "wrangler secret put APPS_SCRIPT_URL"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.90.0"
  }
}
