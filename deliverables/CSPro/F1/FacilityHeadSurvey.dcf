            {
              "name": "Q136_NBB_ALL_PATIENTS",
              "labels": [
                {
                  "text": "136. Are you able to implement it for all patients, to the best of your knowledge, for the last 6 months?",
                  "language": "EN"
                },
                {
                  "text": "Sa abot ng iyong kaalaman, naipapatupad ba ito para sa lahat ng pasyente sa nakaraang 6 na buwan?",
                  "language": "FIL"
                },
                {
                  "text": "Sa saindong pagkaaram, naipapatupad ba nindo ini sa gabos na kwalipikadong pasyente sa nakaaging anom 6 na bulan?",
                  "language": "BCL"
                },
                {
                  "text": "Mahimo ba ninyo kini mapatuman para sa tanang pasyente, base sa inyong kahibalo, sulod sa miaging 6 ka bulan?",
                  "language": "BIS"
                },
                {
                  "text": "Sa inyong kahibalo,nahimo na ba ninyo nga ipatuman kini sa tanan nga kwalipikado nga pasyente sa miaging unom ka buwan?",
                  "language": "CEB"
                },
                {
                  "text": "Nakakahimo ba kamo hini nga ipatuman para han ngatanan nga pasyente, ha iyo nahibabaroan, han naglabay nga 6 ka bulan?",
                  "language": "WAR"
                },
                {
                  "text": "Sa imo pagkatanda sang nagligad nga 6 ka bulan, ginapatuman bala ninyo ini sa tanan nga pasyente?",
                  "language": "HIL"
                }
              ],
              "contentType": "numeric",
              "length": 1,
              "zeroFill": false,
              "valueSets": [
