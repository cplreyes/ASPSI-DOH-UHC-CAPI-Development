            {
              "name": "Q135_NBB_CURR",
              "labels": [
                {
                  "text": "135. Do you currently implement the \"no balance billing\" policy for your patients?",
                  "language": "EN"
                },
                {
                  "text": "Kasalukuyan niyo bang pinapatupad ang \u201cno balance billing\u201d na polisiya para sa inyong mga pasyente?",
                  "language": "FIL"
                },
                {
                  "text": "Sa ngonyan, ipinapatupad nindo an polisiya nin \u201cno balance billing\u201d para sa saindong mga pasyente?",
                  "language": "BCL"
                },
                {
                  "text": "Nagapatuman ba kamo karon sa \"no balance billing\u201d nga polisiya sa inyohang mga pasyente?",
                  "language": "BIS"
                },
                {
                  "text": "Inyo ba nga napatuman sa pagka karon ang \"no balance billing\" policy para sa mga pasyente?",
                  "language": "CEB"
                },
                {
                  "text": "Ginpapatuman ba niyo yana an palisiya nga \"no balance billing\" para han iyo mga pasyente?",
                  "language": "WAR"
                },
                {
                  "text": "Ginapatuman bala ninyo subong ang polisiya nga 'no balance billing' sa mga pasyente?",
                  "language": "HIL"
                }
              ],
              "contentType": "numeric",
              "length": 1,
