              "labels": [
                {
                  "text": "106. What are the resources you need to support/sustain the BUCAS center?",
                  "language": "EN"
                },
                {
                  "text": "Ano ang mga rekurso na kailangan ninyo upang masuportahan/mapanatili ang BUCAS Center?",
                  "language": "FIL"
                },
                {
                  "text": "Ano an mga resources na kaipuhan para masustinera an suporta hali sa BUCAS Center?",
