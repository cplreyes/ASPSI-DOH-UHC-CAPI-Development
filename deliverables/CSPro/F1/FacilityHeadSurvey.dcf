                      "labels": [
                        {
                          "text": "Leading health education and awareness campaigns",
                          "language": "EN"
                        },
                        {
                          "text": "Nangunguna sa mga kampanya sa edukasyong pangkalusugan at pagpapataas ng kamalayan (hal. pagpapalaganap ng kaalaman tungkol sa mga pampublikong inisyatiba sa kalusugan ng DOH, pagpapakalat ng impormasyon tungkol sa kalusugan)",
                          "language": "FIL"
                        },
                        {
                          "text": "Nangengenot sa kampanya sa health education and awareness (hal. pagpopromote kan manlalain na awareness campaigns kan DOH, asin pagtao nin impormasyon manungod sa salud)",
                          "language": "BCL"
                        },
                        {
                          "text": "Pagpanguna sa edukasyon ug pagpahibalo mahitungod sa maayong panglawas",
                          "language": "BIS"
                        },
                        {
                          "text": "Nanguna sa mga kampanya sa edukasyon ug kahibalo sa kahimsog (e.g. Pagpataas sa kahibalo bahin sa mga inisyatiba sa public health sa DOH, pagpakaylap sa impormasyon bahin sa kahimsog)",
                          "language": "CEB"
                        },
                        {
                          "text": "Pagpanguna hin mga kampanya hin edukasyon ngan pagpahibaro parti panlawas (e.g., pagpahibaro mahitungod han mga inisyatibo parti panlawas han publiko han DOH, pagpasamwak hin impormasyon mahitungod han panlawas)",
                          "language": "WAR"
                        },
                        {
                          "text": "Pagpanguna sa kampanya edukasyon sa ikaayong-lawas kag pagpamuklat (e.g. pagpataas sang kamuklatan tuhoy sa public health initiatives sang DOH, pagpalapnag sang impormasyon natuhoy sa ikaayong-lawas)",
                          "language": "HIL"
