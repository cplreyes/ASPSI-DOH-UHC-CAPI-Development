            {
              "name": "Q112_STOCKOUT",
              "labels": [
                {
                  "text": "112. In the past 3 months, has this facility experienced a stock-out (zero supply) of any tracer essential medicines?",
                  "language": "EN"
                },
                {
                  "text": "Sa nakaraang 3 buwan, naranasan ba ng pasilidad na ito na ubos ang stock (walang natitirang supply) ng alinman sa mga tracer essential medicines?",
                  "language": "FIL"
                },
                {
                  "text": "Sa nakaaging 3 bulan, naka-eksperyensya ba an pasilidad nin stock-out (zero supply) nin maski anong tracer essential medicines?",
                  "language": "BCL"
                },
                {
                  "text": "Sa miaging 3 ka bulan, naka-experience ba ang inyong pasilidad og stock-out (walay supply) sa bisan unsang tracer essential medicines?",
                  "language": "BIS"
                },
                {
                  "text": "Sa miaging 3 ka bulan, nakasinati ba kining pasilidad og stock-out (wala'y suplay) sa bisan unsang tracer essential medicines?",
                  "language": "CEB"
                },
                {
                  "text": "Ha naglabay nga 3 ka bulan, nakaeksperyensya ba ini nga pasilidad hin stock-out (waray na suplay) hin bisan ano nga tracer essential na nga medisana?",
                  "language": "WAR"
                },
                {
                  "text": "Sa nagligad nga 3 ka bulan, naka-experyensya bala ini nga pasilidad sang kulang sa stock (wala sang suplay) sang bisan ano nga tracer essential medicines?",
                  "language": "HIL"
                }
