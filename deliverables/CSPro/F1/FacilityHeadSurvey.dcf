              "labels": [
                {
                  "text": "112. In the past 3 months, has this facility experienced a stock-out (zero supply) of any tracer essential medicines?",
                  "language": "EN"
                },
                {
                  "text": "Sa nakaraang 3 buwan, naranasan ba ng pasilidad na ito na ubos ang stock (walang natitirang supply) ng alinman sa mga tracer essential medicines?",
                  "language": "FIL"
                },
                {
                  "text": "Sa nakaaging 3 bulan, naka-eksperyensya ba an pasilidad nin stock-out (zero supply) nin maski anong tracer essential medicines?",
                  "language": "BCL"
