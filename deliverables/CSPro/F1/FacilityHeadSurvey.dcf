            {
              "name": "Q77_ENROLL_CHALL",
              "labels": [
                {
                  "text": "77. Did you experience any challenges in enrolling patients to YAKAP/Konsulta?",
                  "language": "EN"
                },
                {
                  "text": "Nakaranas ka ba ng anumang hamon o suliranin sa pag-enroll nga mga pasyente sa YAKAP/Konsulta.",
