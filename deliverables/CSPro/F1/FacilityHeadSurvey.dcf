              "valueSets": [
                {
                  "name": "Q120_LIC_DAYS_VS1",
                  "labels": [
                    {
                      "text": "120. How many days did it take you to receive the license?",
                      "language": "EN"
                    },
                    {
                      "text": "Ilang araw ang inabot bago niyo natanggap ang lisensiya?",
                      "language": "FIL"
                    },
                    {
                      "text": "Pirang aldaw nagaabot bago makaresibi kan lisensya?",
                      "language": "BCL"
                    },
                    {
                      "text": "Pila ka adlaw ninyo nadawat ang lisensya?",
                      "language": "BIS"
                    },
                    {
                      "text": "Pila ka adlaw ang imong giabot sa pagkuha sa lisensya?",
                      "language": "CEB"
                    },
                    {
                      "text": "Pira ka adlaw an imo gin-agian para makarawat an lisensya?",
                      "language": "WAR"
                    },
                    {
                      "text": "Pila ka adlaw kag nabaton nyo ang inyo lisensya?",
                      "language": "HIL"
                    }
                  ],
                  "values": [
                    {
                      "labels": [
                        {
                          "text": "Less than 30 days",
                          "language": "EN"
                        },
                        {
                          "text": "Mas mababa sa 30 araw",
                          "language": "FIL"
                        },
                        {
                          "text": "Dai man tigaabot ki 30 aldaw",
                          "language": "BCL"
                        },
                        {
                          "text": "Mas mubo sa 30 ka adlaw",
                          "language": "BIS"
                        },
                        {
                          "text": "Ubos sa 30 ka adlaw",
                          "language": "CEB"
                        },
                        {
                          "text": "Waray pa 30 ka adlaw",
                          "language": "WAR"
                        },
                        {
                          "text": "Mas menos sa 30 ka adlaw",
                          "language": "HIL"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "1"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "31-60 days",
                          "language": "EN"
                        },
                        {
                          "text": "31\u201360 araw",
                          "language": "FIL"
                        },
                        {
                          "text": "31-60 na aldaw",
                          "language": "BCL"
                        },
                        {
                          "text": "31 hangtod 60 ka adlaw",
                          "language": "BIS"
                        },
                        {
                          "text": "31-60 ka adlaw",
                          "language": "CEB"
                        },
                        {
                          "text": "31-60 ka adlaw",
                          "language": "WAR"
                        },
                        {
                          "text": "31-60 days",
                          "language": "HIL"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "2"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "More than 60 days",
                          "language": "EN"
                        },
                        {
                          "text": "Higit sa 60 araw",
                          "language": "FIL"
                        },
                        {
                          "text": "Sobra ki 60 na aldaw",
                          "language": "BCL"
                        },
                        {
                          "text": "Sobra sa 60 ka adlaw",
                          "language": "BIS"
                        },
                        {
