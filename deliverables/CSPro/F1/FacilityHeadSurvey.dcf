            {
              "name": "Q154_NUM_REFERRED_OUT",
              "labels": [
                {
                  "text": "154. In the past 6 months, how many patients were referred to a higher-level facility within the referral network?",
                  "language": "EN"
                },
                {
                  "text": "Sa nakalipas na 6 na buwan, ilang pasyente ang na-refer sa mas mataas na antas ng pasilidad sa loob ng network?",
                  "language": "FIL"
                },
                {
                  "text": "Sa nakaaging anom 6 na bulan, pira an bilang kan mga pasyenteng na-refer sa mas mataas na lebel na pasilidad sa laog kan network?",
                  "language": "BCL"
                },
                {
                  "text": "Sa niaging 6 ka bulan, pila kabuok pasyente ang narefer sa mas taas nga lebel sa pasilidad sa inyong referral network?",
                  "language": "BIS"
                },
                {
                  "text": "Sa miaging 6 ka bulan, pila ka mga pasyente ang gi-refer sa mas taas nga lebel nga pasilidad sulod sa referral network?",
                  "language": "CEB"
                },
                {
                  "text": "Ha naglabay nga 6 ka bulan, pira nga pasyente an igintugon ha mas hitaas nga pasilidad ha sakob han network han pagrefer?",
                  "language": "WAR"
                },
                {
                  "text": "Sa nagligad nga 6 ka bulan, pilang ka pasyente ang gin-refer sa mas mataas nga lebel nga pasilidad nga napasulod sang referral network?",
                  "language": "HIL"
                }
              ],
