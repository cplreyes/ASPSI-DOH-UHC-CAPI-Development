                          "text": "Sa sulod sang nagligad nga 4 tubtob 6 ka bulan",
                          "language": "HIL"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "2"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Over 6 months but within 1 year",
                          "language": "EN"
                        },
                        {
                          "text": "Mahigit 6 na buwan ngunit hindi hihigit sa 1 taon",
                          "language": "FIL"
                        },
                        {
                          "text": "Lagpas anom na bulan hanggang 1 na taon",
                          "language": "BCL"
                        },
                        {
                          "text": "Sobra sa 6 ka bulan pero sulod sa 1 ka tuig",
                          "language": "BIS"
                        },
                        {
                          "text": "Labaw sa 6 ka bulan apan sulod sa 1 ka tuig",
                          "language": "CEB"
                        },
                        {
                          "text": "Sobra 6 ka bulan pero ha sakob hin 1 ka tuig",
                          "language": "WAR"
                        },
                        {
                          "text": "Sa masubra sa 6 ka bulan pero sulod sang 1 ka tuig",
                          "language": "HIL"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "3"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "More than 1 year ago",
                          "language": "EN"
                        },
                        {
                          "text": "Higit sa 1 taon na ang nakalipas",
                          "language": "FIL"
                        },
                        {
                          "text": "Lagpas saronag taon",
                          "language": "BCL"
                        },
                        {
                          "text": "sobra pa sa 1 ka tuig ang milabay",
                          "language": "BIS"
                        },
                        {
                          "text": "Kapin sa 1 ka tuig na ang milagi",
                          "language": "CEB"
                        },
                        {
                          "text": "Sobra 1 ka tuig na an nakalabay",
                          "language": "WAR"
                        },
                        {
                          "text": "Mas masubra 1 ka tuig na ang nakaligad",
                          "language": "HIL"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "4"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "I don't know",
                          "language": "EN"
                        },
                        {
                          "text": "Hindi ko alam",
                          "language": "FIL"
                        },
                        {
                          "text": "Dai aram",
                          "language": "BCL"
                        },
                        {
                          "text": "Wala ko kahibalo",
                          "language": "BIS"
                        },
                        {
                          "text": "Wala ko kahibalo",
