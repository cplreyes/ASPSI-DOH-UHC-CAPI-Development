            {
              "name": "Q107_BUCAS_DECONGEST",
              "labels": [
                {
                  "text": "107. Based on your experience, does the BUCAS Center decongest your health facility of patients?",
                  "language": "EN"
                },
                {
                  "text": "Batay sa inyong karanasan, nakatutulong ba ang BUCAS Center na mabawasan ang siksikan ng mga pasyente sa inyong pasilidad ng kalusugan?",
                  "language": "FIL"
                },
                {
                  "text": "Base sa saimong naeksperyensa, an BUCAS Center ba na decongest an health facility kan pasyente?",
                  "language": "BCL"
                },
                {
                  "text": "Base sa imong kasinatian, nakatabang ba ang BUCAS Center sa pagpagaan (decongest) sa inyong health facility sa gidaghanon sa mga pasyente?",
                  "language": "BIS"
                },
