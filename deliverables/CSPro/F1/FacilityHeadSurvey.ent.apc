    errmsg("Select at least one option for Q121 before continuing.");
    reenter;
  endif;
  if pos("90", Q121_DOH_LIC_DIFFICULT) > 0 and length(strip(Q121_DOH_LIC_DIFFICULT)) > 2 then
    errmsg("Q121: an exclusive option (None / No initiatives / Do not know) should be the only choice - please review the options ticked.");
