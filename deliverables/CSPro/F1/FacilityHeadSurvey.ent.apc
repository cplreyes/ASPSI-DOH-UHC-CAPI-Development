PROC Q121_DOH_LIC_DIFFICULT
preproc
  { #385 facility-type-aware option visibility (spec §4.9) }
  if Q8_SERVICE_LEVEL = 1 then   { Primary Care Facility }
    setvalueset(Q121_DOH_LIC_DIFFICULT, Q121_DOH_LIC_DIFFICULT_PCF_VS1);
  else                           { Level 1/2/3 Hospital }
    setvalueset(Q121_DOH_LIC_DIFFICULT, Q121_DOH_LIC_DIFFICULT_HOSP_VS1);
