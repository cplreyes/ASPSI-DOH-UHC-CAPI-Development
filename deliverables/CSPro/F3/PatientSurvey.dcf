            {
              "name": "Q67_WHY_THIS_FACILITY_O01",
              "labels": [
                {
                  "text": "67. Why did you go to this facility instead of your usual facility? \u2014 This facility is more accessible than my usual facility (i.e., nearer, has more transportation options to get to, and cheaper to travel to)",
                  "language": "EN"
                },
                {
                  "text": "Mas accessible ini kumpara sa usual na facility (harani sana, may mas marhay na transportasyon, mas barato)",
                  "language": "BCL"
                },
                {
                  "text": "Mas accessible kini nga pasilidad kaysa sa akong kasagarang pasilidad (pananglitan: mas duol, mas daghang sakyanan padulong didto, ug mas barato ang plete)",
                  "language": "BIS"
                },
                {
                  "text": "Mas dali maabot kining pasilidad kumpara sa akong kasagaran nga pasilidad (pananglitan, mas duol, mas daghan og opsyon sa sakyanan paingon, ug mas barato ang pamasahe)",
                  "language": "CEB"
                },
                {
                  "text": "Mas madali maabot ini nga pasilidad kaysa han akon nahiaraan nga pasilidad (i.e., mas harani, mayda mas damo nga mga opsyon hin sarakyan nga makadtoan, ngan mas barato an pagbiyahe)",
                  "language": "WAR"
                }
