                  "values": [
                    {
                      "labels": [
                        {
                          "text": "Outpatient care (Consultation, procedure, or treatment where the patient visits and leaves within the same day)",
                          "language": "EN"
                        },
                        {
                          "text": "Outpatient care (Konsultasyon, procedure, o paggamot kung saan ang pasyente ay pupunta at uuwi sa parehong araw)",
                          "language": "FIL"
                        },
                        {
                          "text": "Outpatient care (Consultation, procedure, treatment, pagudman na iabot sana sa sarong adlaw)",
                          "language": "BCL"
