              "name": "Q1_IS_PATIENT",
              "labels": [
                {
                  "text": "1. Before we begin, to confirm, are you the patient?",
                  "language": "EN"
                },
                {
                  "text": "Bago kita mag-poon, para makumpirma: ika po ba an pasyente?",
                  "language": "BCL"
                },
                {
                  "text": "Sa dili pa kita magsugod, aron makumpirma, ikaw ba ang pasyente?",
                  "language": "BIS"
                },
                {
                  "text": "Sa wala pa ta magsugod, gusto lang nako ma-confirm \u2013 ikaw ba ang pasyente?",
                  "language": "CEB"
                },
                {
                  "text": "Antes kita magtikang, para la makasiguro, ikaw ba an pasyente?",
                  "language": "WAR"
                }
              ],
              "contentType": "numeric",
              "length": 1,
              "zeroFill": false,
              "valueSets": [
