            {
              "name": "Q45_CATEGORY",
              "labels": [
                {
                  "text": "45. What category of member are you?",
                  "language": "EN"
                },
                {
                  "text": "Formal economy (e.g., mga tawo na nagtratrabaho sa gobyerno o pribado na sektor sa Pilipinas)",
                  "language": "BCL"
                },
                {
                  "text": "Unsang kategorya sa miyembro ka?",
                  "language": "BIS"
                },
                {
                  "text": "Unsa nga kategoriya sa miyembro ka?",
                  "language": "CEB"
                },
                {
                  "text": "Ano nga kategorya ka nga miyembro?",
                  "language": "WAR"
                }
              ],
              "contentType": "numeric",
              "length": 2,
              "zeroFill": true,
              "valueSets": [
                {
                  "name": "Q45_CATEGORY_VS1",
                  "labels": [
                    {
                      "text": "45. What category of member are you?",
                      "language": "EN"
                    },
                    {
                      "text": "Formal economy (e.g., mga tawo na nagtratrabaho sa gobyerno o pribado na sektor sa Pilipinas)",
                      "language": "BCL"
                    },
                    {
                      "text": "Unsang kategorya sa miyembro ka?",
                      "language": "BIS"
                    },
                    {
                      "text": "Unsa nga kategoriya sa miyembro ka?",
                      "language": "CEB"
                    },
                    {
                      "text": "Ano nga kategorya ka nga miyembro?",
                      "language": "WAR"
                    }
                  ],
                  "values": [
                    {
                      "labels": [
                        {
                          "text": "Formal economy (i.e., individuals working in the government or private sector based in the country)",
                          "language": "EN"
                        },
                        {
                          "text": "Formal economy (e.g., mga tawo na nagtratrabaho sa gobyerno o pribado na sektor sa Pilipinas)",
                          "language": "BCL"
                        },
                        {
                          "text": "Formal economy (pananglitan: mga nagtrabaho sa gobyerno o pribadong sektor sulod sa nasud)",
                          "language": "BIS"
                        },
                        {
                          "text": "Formal economy (pananglitan, mga indibidwal nga nagtrabaho sa gobyerno o pribadong sektor dinhi sa nasud)",
                          "language": "CEB"
                        },
                        {
                          "text": "Pormal nga ekonomiya (i.e., mga indibidwal nga nagtatrabaho ha gobyerno o pribado nga sektor nga nakabase ha nasod)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "01"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Informal economy (i.e., unemployed, self-employed, informal workers, Filipinos with dual citizenship, naturalized Filipino citizens, citizens of other countries working and/or residing in the Philippines)",
                          "language": "EN"
                        },
                        {
                          "text": "Informal economy (e.g., unemployed, self-employed, informal workers, mga Filipino na may dual citizenship, naturalized Filipino citizens, o mga banyaga na nagtratrabaho o nakatira sa Pilipinas)",
                          "language": "BCL"
                        },
                        {
                          "text": "Informal economy (pananglitan: walay trabaho, self-employed, informal workers, mga Pilipinong adunay dual citizenship, naturalized Filipino citizens, ug mga citizen sa ubang nasud nga nagtrabaho ug/o nagpuyo sa Pilipinas)",
                          "language": "BIS"
                        },
                        {
                          "text": "Informal economy (pananglitan, walay trabaho, self-employed, mga informal worker, Pilipino nga adunay dual citizenship, naturalized nga Pilipino, mga langyaw nga nagtrabaho ug/o nagpuyo sa Pilipinas)",
                          "language": "CEB"
                        },
                        {
                          "text": "Diri pormal nga ekonomiya (i.e., waray trabaho, nagtatrabaho ha kalugaringon, mga trabahador nga diri pormal, mga Pilipino nga may duha nga pagkalungsoranon, naturalizado nga mga tuminungnong nga Pilipino, mga tuminongnong han iba nga mga nasud nga nagtatrabaho ngan/o naukoy ha Pilipinas)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "02"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Indigent (i.e., individuals who have no visible means of income, or whose income is insufficient for family subsistence based on DSWD's specific criteria)",
                          "language": "EN"
                        },
                        {
                          "text": "Indigent (e.g., mga tawo na daing klarong kita o kulang an kita para sa pagkabuhayi kan pamilya, base sa criteria kan DSWD)",
                          "language": "BCL"
                        },
                        {
                          "text": "Indigent (mga indibidwal nga walay klarong tinubdan sa kita o kulang ang kita alang sa panginabuhi sa pamilya base sa criteria sa DSWD)",
                          "language": "BIS"
                        },
                        {
                          "text": "Indigent (pananglitan, mga indibidwal nga walay klarong tinubdan sa kita, o dili igo ang kita para sa panginabuhian sa pamilya base sa espesipikong sukdanan sa DSWD)",
                          "language": "CEB"
                        },
                        {
                          "text": "Mga kablas (i.e., mga indibidwal nga waray nakikita nga pamaagi hin kita, o kun diin kulang an kita para han panginabuhi han pamilya base han mga partikular nga suruklan han DSWD)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "03"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Sponsored (i.e., members whose contributions are being paid for by another individual, government agencies, or private entities. Includes some low-income citizens that are not indigent e.g. BHWs, PWDs)",
                          "language": "EN"
                        },
                        {
                          "text": "Sponsored (e.g., mga membro na binabayaran nin iba, gobyerno, o pribadong entidad. Kaibahan an iba pang low-income citizens na bakong indigent e.g. BHWs, PWDs)",
                          "language": "BCL"
                        },
                        {
                          "text": "Sponsored (mga miyembro nga ang kontribusyon gibayran sa laing indibidwal, government agencies, o private entities. Apil ang pipila ka low-income citizens nga dili indigent sama sa BHWs ug PWDs)",
                          "language": "BIS"
                        },
                        {
                          "text": "Sponsored (pananglitan, mga miyembro nga ang kontribusyon gibayran sa laing indibidwal, ahensya sa gobyerno, o pribadong entidad. Naglakip sa pipila ka mga low-income nga lungsoranon nga dili indigent sama sa BHW, PWD)",
                          "language": "CEB"
                        },
                        {
                          "text": "Gin-sponsoran (i.e., mga miyembro nga an mga kontribusyon ginbabayaran hin lain nga indibidwal, mga ahensya han gobyerno, o mga pribado nga mga entidad. Nag-uupod hin pipira nga mga tuminungnong nga gutiay la an kita nga diri mga kablas pananglitan, mga BHW, PWD)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "04"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Lifetime member (i.e., individuals aged 60 years and above, uniformed personnel aged 56 years and above, and SSS underground miner-retirees aged 55 years and above and paid at least 120 monthly contributions with PhilHealth and the former Medicare Programs of SSS and GSIS)",
                          "language": "EN"
                        },
                        {
                          "text": "Lifetime member (e.g., mga tawo 60 taon pataas, uniformed personnel 56 taon pataas, asin SSS underground miner-retirees 55 taon pataas na nagbayad nin 120 contributions)",
                          "language": "BCL"
                        },
                        {
                          "text": "Lifetime member (mga indibidwal nga 60 anyos pataas, uniformed personnel nga 56 anyos pataas, ug SSS underground miner-retirees nga 55 anyos pataas ug nakabayad og labing menos 120 ka monthly contributions sa PhilHealth ug sa naunang Medicare Programs sa SSS ug GSIS)",
                          "language": "BIS"
                        },
                        {
                          "text": "Lifetime member (pananglitan, mga indibidwal nga 60 anyos pataas, mga uniformed personnel nga 56 anyos pataas, ug mga retiradong SSS underground miner nga 55 anyos pataas ug nakabayad og labing menos 120 ka bulan nga kontribusyon sa PhilHealth ug sa kanhing Medicare Programs sa SSS ug GSIS)",
                          "language": "CEB"
                        },
                        {
                          "text": "Miyembro ha bug-os nga kinabuhi (i.e., mga indibidwal nga nag-eedad hin 60 anyos tipaigbaw, mga unipormado nga mga tawohan nga nag-eedad hin 56 anyos tipaigbaw, ngan SSS underground miner-retirees nga nag-eedad hin 55 anyos tipaigbaw ngan nagbayad hin diri maubos hin 120 kada bulan nga kontribusyon ha PhilHealth ngan han anay Medicare Programs han SSS ngan GSIS)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "05"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Senior citizen (i.e., residents of the Philippines, aged sixty (60) years or above and are not currently covered by any membership category of PhilHealth and qualified dependents of senior citizen members who are also senior citizen themselves or belonging to other membership categories, with or without coverage who are senior citizens themselves)",
                          "language": "EN"
                        },
                        {
                          "text": "Senior citizen (e.g., residente sa Pilipinas 60 taon pataas, dai sakop nin ano mang membership category, o qualified dependents na senior citizen man)",
                          "language": "BCL"
                        },
                        {
                          "text": "Senior citizen (mga residente sa Pilipinas nga 60 anyos pataas ug dili pa sakop sa ubang membership category sa PhilHealth, ug mga qualified dependents sa senior citizen members nga senior citizens usab o sakop sa ubang membership categories)",
                          "language": "BIS"
                        },
                        {
                          "text": "Senior citizen (pananglitan, mga residente sa Pilipinas, 60 anyos pataas ug wala karon sakop sa bisan unsang kategoriya sa pagkamiyembro sa PhilHealth ug mga kwalipikadong dependent sa mga senior citizen nga miyembro nga senior citizen usab o sakop sa ubang kategoriya sa pagkamiyembro, aduna man o wala'y coverage nga senior citizen usab)",
                          "language": "CEB"
                        },
                        {
                          "text": "(i.e., mga residente ha Pilipinas, nag- edad saysenta (60)anyos o ihbaw pa ngab dire sakop ha bisan ano nga kategorya nga sakop han Philhealth ngan kwalipikado nga dependent han miyembro nga senior citizen o nga sakop han iba nga mga kategorya han mga miyembro, nga mayda o waray sakop nga mga senior citizen mismo)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "06"
                        }
                      ]
