            {
              "name": "Q110_LAB_OUTSIDE",
              "labels": [
                {
                  "text": "110. Other than the laboratory service/s indicated in the hospital bill, did the patient pay for other service/s outside the hospital?",
                  "language": "EN"
                },
                {
                  "text": "Bukod sa mga laboratory service na nnakasama sa bill ng ospital, may binayaran pa ba ang pasyente para sa ibang serbisyo sa labas ng ospital?",
                  "language": "FIL"
                },
                {
                  "text": "Maliban sa mga laboratory services na nakaag sa hospital bill, may binayadan pa ba an pasyente para serbisyo na ginibo sa ibang hospital?",
                  "language": "BCL"
                },
                {
                  "text": "Gawas sa laboratory services nga naa sa hospital bill, nagbayad ba ang pasyente para sa uban pang serbisyo sa gawas sa ospital?",
                  "language": "BIS"
                },
                {
                  "text": "Gawas sa mga laboratory services nga nakabutang sa hospital bill, nagabayad ba ang pasyente para sa uban pang mga serbisyo gawas sa ospital?",
                  "language": "CEB"
                },
                {
                  "text": "Labot la han serbisyo/mga serbisyo ha laboratoryo nga iginpapakita ha baraydan han ospital, nagbayad ba an pasyente hin iba nga serbisyo/mga serbisyo ha gawas han ospital?",
                  "language": "WAR"
                }
