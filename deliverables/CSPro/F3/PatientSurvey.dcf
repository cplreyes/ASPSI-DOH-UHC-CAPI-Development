                      ],
                      "pairs": [
                        {
                          "value": "02"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Indigent (i.e., individuals who have no visible means of income, or whose income is insufficient for family subsistence based on DSWD's specific criteria)"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "03"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Sponsored (i.e., members whose contributions are being paid for by another individual, government agencies, or private entities. Includes some low-income citizens that are not indigent e.g. BHWs, PWDs)"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "04"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Lifetime member (i.e., individuals aged 60 years and above, uniformed personnel aged 56 years and above, and SSS underground miner-retirees aged 55 years and above and paid at least 120 monthly contributions with PhilHealth and the former Medicare Programs of SSS and GSIS)"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "05"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Senior citizen (i.e., residents of the Philippines, aged sixty (60) years or above and are not currently covered by any membership category of PhilHealth and qualified dependents of senior citizen members who are also senior citizen themselves or belonging to other membership categories, with or without coverage who are senior citizens themselves)"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "06"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Overseas Filipino Worker (OFW)"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "07"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Qualified dependents (i.e., those whose contributions are declared and covered by a principal member)"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "08"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "I don't know"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "98"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Other (Specify)"
                        }
