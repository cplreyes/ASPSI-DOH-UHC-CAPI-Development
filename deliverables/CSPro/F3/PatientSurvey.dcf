            {
              "name": "Q162_REFERRED",
              "labels": [
                {
                  "text": "162. Based on your most recent visit/confinement at [facility_name_input], did a healthcare worker refer you to another facility or specialist for further care or specialized care?",
                  "language": "EN"
                },
                {
                  "text": "Base saimong pinakahuring pagbisita o pagkaospital sa [ngaran kan pasilidad], igwa ba na healthcare worker an nagrefer saimo sa ibang pasilidad o specialista?",
                  "language": "BCL"
                },
                {
                  "text": "Base sa imong pinakabag-o nga pagbisita/confinement sa [facility_name_input], gi-refer ba ka sa usa ka healthcare worker ngadto sa laing pasilidad o espesyalista alang sa dugang o espesyal nga pag-atiman?",
                  "language": "BIS"
                },
                {
                  "text": "Base sa imong pinakaulahing pagbisita/pagpa-admit sa [facility_name_input], gi-refer ka ba sa usa ka healthcare worker ngadto sa laing pasilidad o espesyalista para sa dugang nga pag-atiman o espesyal nga pag-atiman?",
                  "language": "CEB"
                },
                {
                  "text": "Basi han imo pinakabag-o nga pagbisita/kaconfine ha [igbutang an ngaran han pasilidad], ginrefer ka ba ha usa nga trabahador han panlawas ngadto hin iba nga pasilidad o espesyalista para hin dugang mga pag-ataman?",
                  "language": "WAR"
                }
              ],
