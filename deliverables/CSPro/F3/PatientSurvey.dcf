                        {
                          "text": "Outpatient care (konsultasyon, procedure, o treatment diin ang pasyente mobisita ug mouli sa maong adlaw)",
                          "language": "BIS"
                        },
                        {
                          "text": "Outpatient care (Konsultasyon, procedure, o treatment diin mobisita ang pasyente ug mouli sulod sa mao ra nga adlaw)",
                          "language": "CEB"
                        },
                        {
                          "text": "Outpatient care (Konsultasyon, pamaagi, o pagtambal kun diin an pasyente nabisita ngan nabaya ha sakob han pareho nga adlaw)",
                          "language": "WAR"
