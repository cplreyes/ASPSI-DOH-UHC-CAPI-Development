            {
              "name": "Q123_ZBB_EXTENT",
              "labels": [
                {
                  "text": "123. To what extent did ZBB reduce your financial burden?",
                  "language": "EN"
                },
                {
                  "text": "Hanggang sain kaya an ZBB nakabawas sa saimong problema sa pambayad?",
                  "language": "BCL"
                },
                {
                  "text": "Hangtod unsa nga lebel nakatabang ang ZBB sa pagpakunhod sa imong pinansyal nga kabug-at?",
                  "language": "BIS"
                },
                {
                  "text": "Hangtod unsa nga ang-ang nakapakunhod ang ZBB sa imong pinansyal nga palas-anon?",
                  "language": "CEB"
                },
                {
                  "text": "Tubtob diin naibanan han ZBB an imo pinansyal nga kabug-at?",
                  "language": "WAR"
                }
              ],
              "contentType": "numeric",
              "length": 1,
              "zeroFill": false,
              "valueSets": [
                {
                  "name": "Q123_ZBB_EXTENT_VS1",
                  "labels": [
                    {
                      "text": "123. To what extent did ZBB reduce your financial burden?",
                      "language": "EN"
                    },
                    {
                      "text": "Hanggang sain kaya an ZBB nakabawas sa saimong problema sa pambayad?",
                      "language": "BCL"
                    },
                    {
                      "text": "Hangtod unsa nga lebel nakatabang ang ZBB sa pagpakunhod sa imong pinansyal nga kabug-at?",
                      "language": "BIS"
                    },
                    {
                      "text": "Hangtod unsa nga ang-ang nakapakunhod ang ZBB sa imong pinansyal nga palas-anon?",
                      "language": "CEB"
                    },
                    {
                      "text": "Tubtob diin naibanan han ZBB an imo pinansyal nga kabug-at?",
                      "language": "WAR"
                    }
                  ],
                  "values": [
                    {
                      "labels": [
                        {
                          "text": "ZBB significantly reduced my financial burden by covering my expenses",
                          "language": "EN"
                        },
                        {
                          "text": "An ZBB nakabawas nin marhay sa problema ko sa pagbayad kan mga naggastos sa pagpabulong",
                          "language": "BCL"
                        },
                        {
                          "text": "Dako kaayo ang natabang sa ZBB sa pagpakunhod sa akong pinansyal nga kabug-at pinaagi sa pagsalo sa akong mga gasto",
                          "language": "BIS"
                        },
                        {
                          "text": "Dako kaayo ang natabang sa ZBB sa pagpakunhod sa akong pinansyal nga palas-anon kay gitabonan niini ang akong mga gasto",
                          "language": "CEB"
                        },
                        {
                          "text": "Gin-ibanan gud han ZBB an akon pinansyal nga kabug-at pinaagi han pagsagot han akon mga gastos",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "1"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "It helped lessen some costs, but I still incurred Out-of-Pocket (OOP) expenses",
                          "language": "EN"
                        },
                        {
                          "text": "Nakatabang siya kan gastos pero nadipisilan pa din kami dahil sa kulang an pambayad",
                          "language": "BCL"
                        },
                        {
                          "text": "Nakatabang kini sa pagpakunhod sa pipila ka gasto, apan adunay gihapon koy Out-of-Pocket (OOP) nga mga bayronon",
                          "language": "BIS"
                        },
                        {
                          "text": "Nakatabang kini sa pagpakunhod sa pipila ka gasto, pero aduna gihapon koy nagasto gikan sa kaugalingong bulsa",
                          "language": "CEB"
                        },
                        {
                          "text": "Nakabulig ito ha pag-iban han pipira nga gastos, kundi nagkaada la gihapon ako mga gastos tikang ha bulsa (OOP)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "2"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "ZBB provided some financial relief, though the support was limited compared to my total needs",
                          "language": "EN"
                        },
                        {
                          "text": "An ZBB nagtatao ki financial na tabang asin suporta pero ini may kakulangan kumpara sa gabos na pangangaipo",
                          "language": "BCL"
                        },
                        {
                          "text": "Nihatag ang ZBB og pipila ka pinansyal nga tabang, apan limitado ra ang suporta kumpara sa akong kinatibuk-ang panginahanglan",
                          "language": "BIS"
                        },
                        {
                          "text": "Ang ZBB nakahatag og gamay nga kahupayan sa pinansyal, pero limitado ang suporta kumpara sa akong kinatibuk-ang panginahanglan",
                          "language": "CEB"
                        },
                        {
                          "text": "An ZBB naghatag hin pipira nga pinansyal nga bulig, bisan kon limitado la an suporta kon itanding ha akon kabug-osan nga panginahanglan",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "3"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "ZBB did not make a noticeable difference in my financial situation",
                          "language": "EN"
                        },
                        {
                          "text": "Wala naman na naitabang ang ZBB",
                          "language": "BCL"
                        },
                        {
                          "text": "Wala\u2019y klarong kausaban nga nahimo ang ZBB sa akong pinansyal nga kahimtang",
                          "language": "BIS"
                        },
                        {
                          "text": "Ang ZBB wala kaayo nakahatag og kalainan sa akong pinansyal nga kahimtang",
                          "language": "CEB"
                        },
                        {
                          "text": "Waray makita nga kaibahan an ZBB ha akon pinansyal nga kahimtang",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "4"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
