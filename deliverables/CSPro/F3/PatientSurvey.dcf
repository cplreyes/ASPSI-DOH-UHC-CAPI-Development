                  ],
                  "values": [
                    {
                      "labels": [
                        {
                          "text": "Formal economy (i.e., individuals working in the government or private sector based in the country)",
                          "language": "EN"
                        },
                        {
                          "text": "Formal economy (hal., mga indibidwal na nagtatrabaho sa gobyerno o pribadong sektor sa loob ng bansa)",
                          "language": "FIL"
                        },
                        {
                          "text": "Formal economy (e.g., mga tawo na nagtratrabaho sa gobyerno o pribado na sektor sa Pilipinas)",
                          "language": "BCL"
                        },
                        {
                          "text": "Formal economy (pananglitan: mga nagtrabaho sa gobyerno o pribadong sektor sulod sa nasud)",
                          "language": "BIS"
                        },
                        {
                          "text": "Formal economy (pananglitan, mga indibidwal nga nagtrabaho sa gobyerno o pribadong sektor dinhi sa nasud)",
                          "language": "CEB"
                        },
                        {
                          "text": "Pormal nga ekonomiya (i.e., mga indibidwal nga nagtatrabaho ha gobyerno o pribado nga sektor nga nakabase ha nasod)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
