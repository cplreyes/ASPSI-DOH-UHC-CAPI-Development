                          "value": "01"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Informal economy (i.e., unemployed, self-employed, informal workers, Filipinos with dual citizenship, naturalized Filipino citizens, citizens of other countries working and/or residing in the Philippines)"
