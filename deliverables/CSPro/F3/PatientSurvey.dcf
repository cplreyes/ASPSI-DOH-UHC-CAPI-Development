            {
              "name": "Q152_GAMOT_HEARD",
              "labels": [
                {
                  "text": "152. Have you heard of the Guaranteed and Accessible Medications for Outpatient Treatment (GAMOT) Package, which is part of PhilHealth's YAKAP/Konsulta or primary care benefit package?",
                  "language": "EN"
                },
