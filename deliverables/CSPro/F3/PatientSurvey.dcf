                      "language": "EN"
                    },
                    {
                      "text": "Anong klase kan serbisyo ang na-access mo?",
                      "language": "BCL"
                    },
                    {
                      "text": "Unsang klase sa serbisyo ang kasagarang gi-access sa pasyente?",
                      "language": "BIS"
                    },
                    {
                      "text": "Unsa nga klase sa serbisyo ang kasagarang giadto sa pasyente?",
                      "language": "CEB"
                    },
                    {
                      "text": "Ano nga klase hin serbisyo an kasagaran nga nakukuha han pasyente?",
                      "language": "WAR"
                    }
                  ],
                  "values": [
                    {
                      "labels": [
                        {
                          "text": "Outpatient care (Consultation, procedure, or treatment where the patient visits and leaves within the same day)",
                          "language": "EN"
                        },
                        {
                          "text": "Outpatient care (Consultation, procedure, treatment, pagudman na iabot sana sa sarong adlaw)",
                          "language": "BCL"
                        },
                        {
                          "text": "Outpatient care (konsultasyon, procedure, o treatment diin ang pasyente mobisita ug mouli sa maong adlaw)",
                          "language": "BIS"
                        },
                        {
                          "text": "Outpatient care (Konsultasyon, procedure, o treatment diin mobisita ang pasyente ug mouli sulod sa mao ra nga adlaw)",
                          "language": "CEB"
                        },
                        {
                          "text": "Outpatient care (Konsultasyon, pamaagi, o pagtambal kun diin an pasyente nabisita ngan nabaya ha sakob han pareho nga adlaw)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "1"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Inpatient care (Care provided in hospital or another facility where the patient is admitted for at least one night)",
                          "language": "EN"
                        },
                        {
                          "text": "Inpatient care (Care sa hospital o facility kung saen admitted ang pasyente atleast sarong banggi)",
                          "language": "BCL"
                        },
                        {
                          "text": "Inpatient care (pag-atiman sa ospital o laing pasilidad diin gi-admit ang pasyente og labing menos usa ka gabii)",
                          "language": "BIS"
                        },
                        {
                          "text": "Inpatient care (Pag-atiman nga gihatag sa ospital o laing pasilidad diin ma-admit ang pasyente sulod sa labing menos usa ka gabii)",
                          "language": "CEB"
                        },
                        {
                          "text": "Inpatient care (Pag-ataman nga iginhatag ha ospital o ha iba nga pasilidad kun diin an pasyente in naka-admit hin diri maubos hin usa ka gab-i)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "2"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Emergency care (Care for serious illnesses or injuries that need immediate medical attention; usually provided in an emergency room or ER)",
                          "language": "EN"
                        },
                        {
                          "text": "Emergency care (Serious illnesses o injuries, immediate attention, kadaklan sa ER)",
                          "language": "BCL"
                        },
                        {
                          "text": "Emergency care (pag-atiman alang sa seryosong sakit o injury nga nanginahanglan dayon nga medical attention; kasagarang gihimo sa emergency room o ER)",
                          "language": "BIS"
                        },
                        {
                          "text": "Emergency care (Pag-atiman para sa seryoso nga mga sakit o samad nga nanginahanglan og dinaliang medikal nga atensyon; kasagaran gihatag sa emergency room o ER)",
                          "language": "CEB"
                        },
                        {
                          "text": "Emergency care (Pag-ataman han grabe nga mga sakit o samad nga nagkikinahanglan hin kadagmitan nga atensyon medikal; kasagaran iginhahatag ha emergency room o ER)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "3"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Primary care consultation",
                          "language": "EN"
                        },
                        {
                          "text": "Primary care consultation",
                          "language": "BCL"
                        },
                        {
                          "text": "Primary care consultation",
                          "language": "BIS"
                        },
                        {
                          "text": "Konsultasyon sa primary care",
                          "language": "CEB"
                        },
                        {
                          "text": "Konsultasyon ha panguna nga pag-ataman",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "4"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Other (Specify)",
                          "language": "EN"
                        },
                        {
                          "text": "Iba pa (ispecify)",
                          "language": "BCL"
                        },
                        {
                          "text": "Uban pa (I-specify)",
                          "language": "BIS"
                        },
                        {
                          "text": "Uban pa (isulti)",
                          "language": "CEB"
                        },
                        {
                          "text": "Iba pa (Ispecify)",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "5"
                        }
                      ]
                    }
                  ]
                }
              ]
