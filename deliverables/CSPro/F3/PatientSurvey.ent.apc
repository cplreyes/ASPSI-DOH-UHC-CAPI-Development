    reenter;
  endif;

PROC Q72_NEAREST_TRAVEL_MM
postproc
  if Q72_NEAREST_TRAVEL_MM < 0 or Q72_NEAREST_TRAVEL_MM > 59 then
    errmsg("Q72_NEAREST_TRAVEL_MM must be between 0 and 59.");
    reenter;
  endif;

PROC Q97_FINAL_AMOUNT
postproc
  if Q97_FINAL_AMOUNT < 0 or Q97_FINAL_AMOUNT > 99999999 then
    errmsg("Q97_FINAL_AMOUNT must be between 0 and 99999999.");
    reenter;
  endif;
  if Q97_FINAL_AMOUNT > 0 and (Q92_PAY_01_AMT + Q94_PAY_01_AMT + Q96_PAY_01_AMT) > 0
     and (Q97_FINAL_AMOUNT < (Q92_PAY_01_AMT + Q94_PAY_01_AMT + Q96_PAY_01_AMT) * 0.9
          or Q97_FINAL_AMOUNT > (Q92_PAY_01_AMT + Q94_PAY_01_AMT + Q96_PAY_01_AMT) * 1.1) then
    errmsg("Q97 final amount differs by more than 10 percent from the out-of-pocket lines (Q92/Q94/Q96) — confirm.");
  endif;

PROC Q106_NIGHTS
postproc
  if Q106_NIGHTS < 0 or Q106_NIGHTS > 365 then
    errmsg("Q106_NIGHTS must be between 0 and 365.");
    reenter;
  endif;
  if Q106_NIGHTS > 90 then
    errmsg("Q106_NIGHTS = %d is unusually high — confirm.", Q106_NIGHTS);
  endif;

PROC Q115_FINAL_CASH
postproc
  if Q115_FINAL_CASH < 0 or Q115_FINAL_CASH > 999999999 then
    errmsg("Q115_FINAL_CASH must be between 0 and 999999999.");
    reenter;
  endif;
  if Q107_PAY_01_AMT > 0 and (Q115_FINAL_CASH < Q107_PAY_01_AMT * 0.9
     or Q115_FINAL_CASH > Q107_PAY_01_AMT * 1.1) then
    errmsg("Q115 final cash differs by more than 10 percent from the out-of-pocket bill line (Q107) — confirm.");
  endif;

PROC Q150_TRAVEL_HH
postproc
  if Q150_TRAVEL_HH < 0 or Q150_TRAVEL_HH > 24 then
    errmsg("Q150_TRAVEL_HH must be between 0 and 24.");
    reenter;
  endif;

PROC Q150_TRAVEL_MM
postproc
  if Q150_TRAVEL_MM < 0 or Q150_TRAVEL_MM > 59 then
    errmsg("Q150_TRAVEL_MM must be between 0 and 59.");
    reenter;
  endif;
  if Q145_PURCHASE_FREQ <> 5 and Q150_TRAVEL_HH = 0 and Q150_TRAVEL_MM = 0 then
    errmsg("Q150 travel time to pharmacy is 0h 0m — confirm the pharmacy is effectively on-site.");
  endif;

PROC Q106_DAYS
postproc
  if Q106_DAYS < 0 or Q106_DAYS > 365 then
    errmsg("Q106_DAYS must be between 0 and 365.");
    reenter;
  endif;
  if Q106_DAYS > 90 then
    errmsg("Length of stay (%d days) is unusually long — confirm.", Q106_DAYS);
  endif;
  if Q106_NIGHTS + Q106_DAYS < 1 then
    errmsg("A confinement must be at least 1 day (nights + days).");
    reenter;
  endif;

PROC DATE_FINAL_VISIT
postproc
  if DATE_FINAL_VISIT < DATE_FIRST_VISITED then
    errmsg("Final-visit date cannot be earlier than the first-visit date.");
    reenter;
  endif;

{ ---- Soft plausibility cross-field warnings (spec §3.5-§3.13) ---- }
PROC Q84_SERVICE_TYPE
postproc
  if Q84_SERVICE_TYPE = 1 and PATIENT_TYPE = 2 then
    errmsg("Q84 = Outpatient care but the case is flagged Inpatient (PATIENT_TYPE) — verify routing.");
  endif;
  if Q84_SERVICE_TYPE = 2 and PATIENT_TYPE = 1 then
    errmsg("Q84 = Inpatient care but the case is flagged Outpatient (PATIENT_TYPE) — verify routing.");
  endif;

PROC Q85_CONDITIONS_O19
postproc
  if Q83_VISIT_REASON = 4 and Q85_CONDITIONS_O19 <> 1 then
    errmsg("Q83 = general check-up but Q85 is not 'No condition / regular check-up only' — confirm.");
  endif;
  { #435: 'No condition - Regular check-up only' (19) should stand alone — warn if combined (mirrors Q148) }
  if Q85_CONDITIONS_O19 = 1 and (Q85_CONDITIONS_O01 = 1 or Q85_CONDITIONS_O02 = 1 or
      Q85_CONDITIONS_O03 = 1 or Q85_CONDITIONS_O04 = 1 or Q85_CONDITIONS_O05 = 1 or
      Q85_CONDITIONS_O06 = 1 or Q85_CONDITIONS_O07 = 1 or Q85_CONDITIONS_O08 = 1 or
      Q85_CONDITIONS_O09 = 1 or Q85_CONDITIONS_O10 = 1 or Q85_CONDITIONS_O11 = 1 or
      Q85_CONDITIONS_O12 = 1 or Q85_CONDITIONS_O13 = 1 or Q85_CONDITIONS_O14 = 1 or
      Q85_CONDITIONS_O15 = 1 or Q85_CONDITIONS_O16 = 1 or Q85_CONDITIONS_O17 = 1 or
      Q85_CONDITIONS_O18 = 1 or Q85_CONDITIONS_O20 = 1) then
    errmsg("'No condition - Regular check-up only' was ticked with other condition(s) — it should usually be the only choice. Please review.");
  endif;

PROC Q144_QUALITY
postproc
  if Q143_RECOMMEND = 1 and Q144_QUALITY >= 4 and Q144_QUALITY <= 5 then
    errmsg("Patient would recommend (Q143=Yes) yet rated overall quality dissatisfied (Q144) — confirm.");
  endif;
  if Q143_RECOMMEND = 2 and Q144_QUALITY >= 1 and Q144_QUALITY <= 2 then
    errmsg("Patient would NOT recommend (Q143=No) yet rated overall quality satisfied (Q144) — confirm.");
  endif;

PROC Q17_INCOME_SOURCE
postproc
  if (Q16_EMPLOYMENT = 4 or Q16_EMPLOYMENT = 5) and Q17_INCOME_SOURCE >= 1 and Q17_INCOME_SOURCE <= 5 then
    errmsg("Q16 = unemployed but Q17 reports a paid-work income source — confirm.");
  endif;

PROC Q29_SEC_CLASS
postproc
  if Q29_SEC_CLASS = 1 and Q18_INCOME_BRACKET >= 1 and Q18_INCOME_BRACKET <= 2 then
    errmsg("Q29 = socio-economic Class A/B but income is in the lowest bracket — confirm.");
  endif;
  if Q29_SEC_CLASS = 3 and Q18_INCOME_BRACKET >= 4 then
    errmsg("Q29 = socio-economic Class D/E but income is in a high bracket — confirm.");
  endif;

