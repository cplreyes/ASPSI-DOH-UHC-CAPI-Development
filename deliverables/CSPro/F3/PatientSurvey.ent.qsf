  - name: PATIENTSURVEY_DICT.Q16_EMPLOYMENT
    conditions:
      - questionText:
          EN: |
            <p>16. What is the patient's employment status?</p><p class="instruction">READ OPTIONS OUT LOUD. SELECT ONE ANSWER ONLY.</p>
          FIL: |
            <p>Ano ang katayuan sa trabaho ng pasyente?</p><p class="instruction">READ OPTIONS OUT LOUD. SELECT ONE ANSWER ONLY.</p>
          BCL: |
            <p>Ano an estado kan trabaho mo?</p><p class="instruction">READ OPTIONS OUT LOUD. SELECT ONE ANSWER ONLY.</p>
          BIS: |
