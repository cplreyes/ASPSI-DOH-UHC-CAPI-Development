    conditions:
      - questionText:
          EN: |
            <p>165. How did they refer you to the doctor?</p><p class="instruction">READ OPTIONS OUT LOUD. SELECT ONE ANSWER ONLY.</p>
          FIL: |
            <p>Paano ka inirefer sa doktor?</p><p class="instruction">READ OPTIONS OUT LOUD. SELECT ONE ANSWER ONLY.</p>
          BCL: |
            <p>Paano ka ninda ni-refer sa doktor?</p><p class="instruction">READ OPTIONS OUT LOUD. SELECT ONE ANSWER ONLY.</p>
          BIS: |
            <p>Giunsa ka nila pag-refer ngadto sa doktor?</p><p class="instruction">READ OPTIONS OUT LOUD. SELECT ONE ANSWER ONLY.</p>
          CEB: |
