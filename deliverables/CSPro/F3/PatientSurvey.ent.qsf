    conditions:
      - questionText:
          EN: |
            <p>121. What is your understanding about ZBB? — No cash payment required upon discharge</p>
          BCL: |
            <p>Warang cash payment bago pa idischarge</p>
          BIS: |
            <p>Walay cash nga bayranon sa pag-discharge</p>
          CEB: |
