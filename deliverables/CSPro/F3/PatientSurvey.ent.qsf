  - name: PATIENTSURVEY_DICT.Q30_IP
    conditions:
      - questionText:
          EN: |
            <p>30. Is the patient member of Indigenous People (IP) community, like the Igorot, Lumad, Mangyans, etc.?</p><p class="instruction">DO NOT READ OPTIONS OUT LOUD. SELECT ONE ANSWER ONLY.</p>
          FIL: |
