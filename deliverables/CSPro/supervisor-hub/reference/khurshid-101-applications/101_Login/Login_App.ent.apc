PROC LOGIN_APP_ID

{
Preproc
Numeric Sel_Option= accept(Concat(strip(loadsetting("Save_Name")), " is login as Supervisor"),
									"ASSIGN ENUMERATION AREA                        ",  {01}
									"   +   Assign Enumeration Area                 ",	{02}
									"   +   Send Enumeration Area to the Enumerator ",	{03}
									"												",	{04}
									"LISTING DATA                                   ",  {05}
									"   +   Receive Listing Data from Enumerator    ",	{06}
									"   +   Send Listing Data on the Server			",	{07}
									"   +   View Listing Report 					",  {08}
									"												",	{09}
									"HOUSEHOLD INTERVIEW                            ",  {10}
									"   +   Receive HH Data from the Enumerator		",	{11}
									"   +   Send Household Data on the Server       ",	{12}
									"   +   View Household Inteview Report			",	{13}
									"												",	{14}
									"TO VIEW EA ON GOOGLE EARTH                     ", 	{15}
									"   +   Set MAP File                            ",	{16}
									"   +   View Your Location on the Map           ",  {17}
									"   +   View Your Listing on the Map            ",  {18}
									"												",	{19}
									"Application Close                              ");	{20}
	endif;
}


Postproc


	{	USERNAMEPASSWORD_ID = from exteranl dictionary
		LOGIN_APP_ID 		= from Working Dictionary	}
	USERNAMEPASSWORD_ID=LOGIN_APP_ID;
	if loadcase(USERNAMEPASSWORD_DICT,USERNAMEPASSWORD_ID)>0 then {Load Case}
		{if operating system is Android then we will confirm device id for login}
		if getos()=20 and getdeviceid() = USERNAMEPASSWORD_DICT.DEVICE_ID then
			LOGIN_NAME=USER_NAME;
			LOGIN_APP_DICT.DEVICE_ID=getdeviceid();
			DESIGNATION=ROLE;
						set attributes (LOGIN_NAME) protect;
						set attributes (LOGIN_APP_DICT.DEVICE_ID) protect;
						set attributes (DESIGNATION) protect;
			{if operating system is Windows then we will not confirm device id for login}
		elseIf getos()=10 then
			LOGIN_NAME=USER_NAME;
			LOGIN_APP_DICT.DEVICE_ID=USERNAMEPASSWORD_DICT.DEVICE_ID;
			DESIGNATION=ROLE;
						set attributes (LOGIN_NAME) protect;
						set attributes (LOGIN_APP_DICT.DEVICE_ID) protect;
						set attributes (DESIGNATION) protect;
		else
			errmsg ("Entered Login ID is Not for this Tablet");
			$=notappl;
			LOGIN_NAME="";
			LOGIN_APP_DICT.DEVICE_ID="";
			DESIGNATION=notappl;
			reenter;
		endif
	else
		errmsg ("Entered Login ID Does Not Exist");
		$=notappl;
		LOGIN_NAME="";
		LOGIN_APP_DICT.DEVICE_ID="";
		DESIGNATION=notappl;
		reenter;
	endif

PROC APP_VERSION

Preproc
	{ ********************************** }
	{ ****    APPLICATION VERSION   **** }

	FindResult =fileexist ("..\103_Ext_Data\Version.txt");
	
	if FindResult=1 then
		setfile (AppVersion, "..\103_Ext_Data\Version.txt");

		{*****************************************************}
		{** IF MORE THAN ONE VERSIONS INFORMATION EXIST THEN**}
		{**       GET LATEST VERSION NUMBER                 **}

		while fileread (AppVersion, PreLoad_Data) do;
					$=tonumber(PreLoad_Data[1:4]);
		enddo;

		{******************************************}
		{**                 END                  **}
		{******************************************}
		Close (AppVersion);
	else

		$=0.01;
		setfile (AppVersion, "..\103_Ext_Data\Version.txt",create);
		PreLoad_Data=concat("0.01 STARTING DATE IS ",  edit("99-99-9999",sysdate("DDMMYYYY")));
		filewrite(AppVersion, "%s",PreLoad_Data);
		close(AppVersion);

	endif;
	{ ****    APPLICATION VERSION   **** }
	{ ********************************** }
PROC PASSWORD



	If USER_PASSWORD<>$ or  $=notappl then

		errmsg ("%s's Password is not Correct.", strip(LOGIN_NAME));
		reenter;

	else


		StartMenu();


//	close(HTMLFile);

	endif;


