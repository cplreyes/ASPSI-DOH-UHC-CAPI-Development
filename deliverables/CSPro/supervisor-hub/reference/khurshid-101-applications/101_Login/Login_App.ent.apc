{						Write Functions						  }
Function StartMenu()
	savesetting("Save_LoginID",  LOGIN_APP_ID);
	savesetting("Save_Name", LOGIN_NAME);
	savesetting("Login_Role", ROLE);
	savesetting("Save_SupID", SUPERVISOR_ID);
		
		menuapp_pff.setproperty("Version", "CSPro 7.7");
		menuapp_pff.setproperty("AppType", "Entry");
		menuapp_pff.setproperty("StartMode", "Add");
		menuapp_pff.setproperty("FullScreen", "Yes");
		menuapp_pff.setproperty("Application", "..\106_Menu\menuapplication.ent");
		menuapp_pff.setproperty("HTMLDialogs", "..\109_HTMLDialogs");
		menuapp_pff.setproperty("InputData", "|type=None");
		menuapp_pff.setproperty("OnExit","../101_login/Login_App.pff");
	//	menuapp_pff.save("..\106_Menu\menuapplication.pff");	
		menuapp_pff.exec();
end;






{saveparameter = concat(edit("9999", LOGIN_APP_ID),
										LOGIN_NAME,
						   edit("9",	ROLE),						  
						   edit("9999",	SUPERVISOR_ID));
		menuapp_pff.setproperty("xyz", saveparameter);
		menuapp_pff.setproperty("logininfo", LOGIN_APP_ID);
		menuapp_pff.setproperty("nameinfo", LOGIN_NAME);
		menuapp_pff.setproperty("roleinfo", ROLE);
		menuapp_pff.setproperty("supidinfo", SUPERVISOR_ID);
}






		
Function OnChangeLanguage()


setvaluesets(concat("_", getlanguage()));
savesetting("SaveLast_Preference", getlanguage());


{
	if getlanguage()="EN" then
		setlanguage("EN");
		setvaluesets("_EN");
		savesetting("SaveLast_Preference", "EN");
	
	elseif getlanguage()="UR" then
		setlanguage("UR");
		setvaluesets("_UR");
		savesetting("SaveLast_Preference", "UR");

	endif;
}
end;


























