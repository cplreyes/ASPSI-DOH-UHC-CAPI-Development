{Application 'LOGIN_APP' logic file generated by CSPro}
PROC GLOBAL

{** DEFINE STRING  **}
	String	PreLoad_Data;

{** DEFINE NUMERIC **}
	Numeric	FindResult;


{**   DEFINE FILE  **}
