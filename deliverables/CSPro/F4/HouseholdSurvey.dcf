              "name": "Q89_HAS_USUAL_FACILITY",
              "labels": [
                {
                  "text": "89. In the past 12 months, do you have a clinic, or health center that you usually go to?",
                  "language": "EN"
                },
                {
                  "text": "Sa nakaaging 12 bulan, may aram ka na clinic, o health center na pirmi mo pigdudumanan? Ano an ngaran kan pasilidad?",
                  "language": "BCL"
                },
                {
                  "text": "Sa milabay nga 12 ka bulan, aduna ba kay klinika o health center nga kasagarang adtoan? Unsa ang ngalan sa pasilidad?",
                  "language": "BIS"
                },
                {
                  "text": "Sa miaging 12 ka bulan, aduna ba kang klinika o health center nga kasagaran nimong adtoan? Unsa ang pangalan sa pasilidad?",
                  "language": "CEB"
