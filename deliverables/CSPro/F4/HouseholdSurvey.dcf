                  "values": [
                    {
                      "labels": [
                        {
                          "text": "Formal economy",
                          "language": "EN"
                        },
                        {
                          "text": "Formal economy (e.g., mga tawo na nagtratrabaho sa gobyerno o pribado na sektor sa Pilipinas)",
                          "language": "BCL"
                        },
                        {
                          "text": "Formal nga ekonomiya (pananglitan: mga nagtrabaho sa gobyerno o pribadong kompanya sa nasud)",
