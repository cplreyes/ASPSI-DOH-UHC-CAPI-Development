            {
              "name": "Q91_WHY_WENT_O01",
              "labels": [
                {
                  "text": "91. Why did you go to this facility? \u2014 This facility is more accessible than my usual facility (i.e., nearer, has more transportation options to get to, and cheaper to travel to)",
                  "language": "EN"
                },
                {
                  "text": "Mas accessible ini kumpara sa dati kung pigduduman na pasilidad (harani, may mas marhay na transportasyon, mas barato an pamasahe)",
                  "language": "BCL"
                },
                {
                  "text": "Mas dali maadtoan kini nga pasilidad kaysa akong kasagarang adtoan (pananglitan: mas duol, mas daghan sakyanan padulong didto, ug mas barato ang plete)",
                  "language": "BIS"
                },
                {
                  "text": "Mas dali maabot kining pasilidad kumpara sa akong kasagaran nga pasilidad (pananglitan, mas duol, mas daghan og opsyon sa sakyanan paingon, ug mas barato ang pamasahe)",
                  "language": "CEB"
                },
                {
                  "text": "Mas madali maabot ini nga pasilidad kaysa han akon nahiaraan nga pasilidad (i.e., mas harani, mayda mas damo nga mga opsyon hin sarakyan nga makadtoan, ngan mas barato an pagbiyahe)",
                  "language": "WAR"
                }
