          "items": [
            {
              "name": "Q1_IS_HH_HEAD",
              "labels": [
                {
                  "text": "1. Before we begin, to confirm, are you the household head?",
                  "language": "EN"
                },
                {
                  "text": "Bago tayo magsimula, upang makumpirma, kayo po ba ang pinuno ng sambahayan?",
                  "language": "FIL"
                },
                {
                  "text": "Bago kita mag-poon, para makumpirma: ika ba an pasyente?",
                  "language": "BCL"
                },
                {
                  "text": "Sa dili pa kita magsugod, aron makompirma, ikaw ba ang punoan sa panimalay?",
                  "language": "BIS"
                },
                {
                  "text": "Sa wala pa ta magsugod, ikaw ba ang ulo sa panimalay?",
                  "language": "CEB"
                },
                {
                  "text": "Ugsa kita magtikang, para la makasiguro, ikaw ba an ulo han panimalay?",
                  "language": "WAR"
                }
              ],
              "contentType": "numeric",
              "length": 1,
              "zeroFill": false,
              "valueSets": [
                {
