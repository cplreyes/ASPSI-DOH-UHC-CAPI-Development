            {
              "name": "Q108_REFERRED",
              "labels": [
                {
                  "text": "108. In the past 6 months, did a healthcare worker refer you to another facility or specialist for further care or specialized care?",
                  "language": "EN"
                },
                {
                  "text": "Sa nakaaging 6 anom na bulan, may nagrefer ba saimo na healthcare worker sa ibang pasilidad o especialista para sa specialized care?",
                  "language": "BCL"
                },
                {
                  "text": "Sa milabay nga 6 ka bulan, adunay ba healthcare worker nga nag-refer nimo ngadto sa lain nga pasilidad o espesyalista alang sa dugang o espesyal nga pag-atiman?",
                  "language": "BIS"
                },
                {
                  "text": "Sa miaging 6 ka bulan, gi-refer ka ba sa usa ka healthcare worker ngadto sa laing pasilidad o espesyalista para sa dugang nga pag-atiman o espesyal nga pag-atiman?",
                  "language": "CEB"
                },
                {
                  "text": "Han naglabay nga 6 ka bulan, mayda ba na trabaho ha healthcare nga nagrefer ha imo ha iba nga pasilidad o espesyalista para hin dugang nga pag-ataman o espesyalista nga pag-ataman?",
                  "language": "WAR"
                }
