          "items": [
            {
              "name": "Q101_CHECKUP_FREQ",
              "labels": [
                {
                  "text": "101. How often do you/your household member have a general check-up on your health (i.e., when you feel healthy, without any specific illness)?",
                  "language": "EN"
                },
                {
                  "text": "Gaano kadalas ka o ang miyembro ng iyong sambahayan ay nagpapasuri ng pangkalahatang kalusugan (hal. kapag pakiramdam ay malusog, walang partikular na sakit)?",
                  "language": "FIL"
                },
                {
                  "text": "Pira ka beses ka o miembro kan saimong pamilya nagpapa general check-up sa saimong salud (hal. kun marhay an pakiramdam mo asin mayong espesipikong sakit)?",
                  "language": "BCL"
                },
                {
                  "text": "Kasagaran, kapila ka o ang ubang miyembro sa imong pamilya magpa-general checkup maskin walay sakit nga ginabati?",
                  "language": "BIS"
                },
                {
                  "text": "Unsa ka sagad ka/kamo sa inyong panimalay magpa-general check-up sa panglawas (kung himsog mo, walay espesipikong sakit)?",
                  "language": "CEB"
                },
                {
                  "text": "Mationan-o kaagsob nga ikaw/imo kapamilya in mayda general check-up or general nga check-up han imo panlawas (i.e., kun san-o ka umabat hin kahimsog, waray bisan ano nga partikular nga sakit)?",
                  "language": "WAR"
                }
              ],
              "contentType": "numeric",
              "length": 1,
              "zeroFill": false,
              "valueSets": [
                {
                  "name": "Q101_CHECKUP_FREQ_VS1",
                  "labels": [
                    {
                      "text": "101. How often do you/your household member have a general check-up on your health (i.e., when you feel healthy, without any specific illness)?",
                      "language": "EN"
                    },
                    {
                      "text": "Gaano kadalas ka o ang miyembro ng iyong sambahayan ay nagpapasuri ng pangkalahatang kalusugan (hal. kapag pakiramdam ay malusog, walang partikular na sakit)?",
                      "language": "FIL"
                    },
                    {
                      "text": "Pira ka beses ka o miembro kan saimong pamilya nagpapa general check-up sa saimong salud (hal. kun marhay an pakiramdam mo asin mayong espesipikong sakit)?",
                      "language": "BCL"
                    },
                    {
                      "text": "Kasagaran, kapila ka o ang ubang miyembro sa imong pamilya magpa-general checkup maskin walay sakit nga ginabati?",
                      "language": "BIS"
                    },
                    {
                      "text": "Unsa ka sagad ka/kamo sa inyong panimalay magpa-general check-up sa panglawas (kung himsog mo, walay espesipikong sakit)?",
                      "language": "CEB"
                    },
                    {
                      "text": "Mationan-o kaagsob nga ikaw/imo kapamilya in mayda general check-up or general nga check-up han imo panlawas (i.e., kun san-o ka umabat hin kahimsog, waray bisan ano nga partikular nga sakit)?",
                      "language": "WAR"
                    }
                  ],
                  "values": [
                    {
                      "labels": [
                        {
                          "text": "More than once a year",
                          "language": "EN"
                        },
                        {
                          "text": "Higit sa isang beses sa isang taon",
                          "language": "FIL"
                        },
                        {
                          "text": "Sobra sa sarong beses kada taon",
                          "language": "BCL"
                        },
                        {
                          "text": "Labaw sa kausa matag tuig",
                          "language": "BIS"
                        },
                        {
                          "text": "Lapas kausa sa usa ka tuig",
                          "language": "CEB"
                        },
                        {
                          "text": "Sobra makausa ha usa ka tuig",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "1"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Every year",
                          "language": "EN"
                        },
                        {
                          "text": "Taun-taon",
                          "language": "FIL"
                        },
                        {
                          "text": "Kada taon",
                          "language": "BCL"
                        },
                        {
                          "text": "matag tuig",
                          "language": "BIS"
                        },
                        {
                          "text": "Kada tuig",
                          "language": "CEB"
                        },
                        {
                          "text": "Kada tuig",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "2"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Every 2-3 years",
                          "language": "EN"
                        },
                        {
                          "text": "Tuwing 2\u20133 taon",
                          "language": "FIL"
                        },
                        {
                          "text": "Kada 2\u20133 na taon",
                          "language": "BCL"
                        },
                        {
                          "text": "Kada 2-3 ka tuig",
                          "language": "BIS"
                        },
                        {
                          "text": "Kada duha hangtud tulo ka tuig",
                          "language": "CEB"
                        },
                        {
                          "text": "Kada 2-3 ka tuig",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "3"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Every 4-5 years",
                          "language": "EN"
                        },
                        {
                          "text": "Tuwing 4\u20135 taon",
                          "language": "FIL"
                        },
                        {
                          "text": "Kada 4\u20135 na taon",
                          "language": "BCL"
                        },
                        {
                          "text": "Kada 4-5 ka tuig",
                          "language": "BIS"
                        },
                        {
                          "text": "Kada upat hangtud lima ka tuig",
                          "language": "CEB"
                        },
                        {
                          "text": "Kada 4-5 ka tuig",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "4"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "No set time; I've only ever done this once or twice in my life",
                          "language": "EN"
                        },
                        {
                          "text": "Walang nakatakdang oras; minsan o ilang beses ko lang nagawa sa buong buhay",
                          "language": "FIL"
                        },
                        {
                          "text": "Mayong nakatakdang oras; minsan o duwang beses ko pa sana ini nagibo sa bilog kong buhay",
                          "language": "BCL"
                        },
                        {
                          "text": "Walay eksaktong oras; kausa o kaduha ra nako kini nabuhat sa tibuok kinabuhi",
                          "language": "BIS"
                        },
                        {
                          "text": "Walay gitakdang oras; kausa o kaduha ra ko nakabuhat ani sa tibuok nakong kinabuhi",
                          "language": "CEB"
                        },
                        {
                          "text": "Waray gintalaan nga oras; Makausa o makaduha la ako hini nabuhat ha akon kinabuhi.",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "5"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Never; I only go to the doctor when I am sick",
                          "language": "EN"
                        },
                        {
                          "text": "Hindi kailanman; nagpapatingin lang ako kapag may sakit",
                          "language": "FIL"
                        },
                        {
                          "text": "Dai, nagpapa-doctor sana ako kun may hilang ako",
                          "language": "BCL"
                        },
                        {
                          "text": "Wala gyud; moadto ra ko sa doktor kung magsakit ko",
                          "language": "BIS"
                        },
                        {
                          "text": "Wala gayud, muadto ra ko sa doktor kung masakit ko",
                          "language": "CEB"
                        },
                        {
                          "text": "Waray gud; Nakadto la ako ha doktor kun may sakit ako.",
                          "language": "WAR"
                        }
                      ],
                      "pairs": [
                        {
                          "value": "6"
                        }
                      ]
                    },
                    {
                      "labels": [
                        {
                          "text": "Other (Specify)",
                          "language": "EN"
                        },
                        {
                          "text": "Iba pa (tukuyin)",
                          "language": "FIL"
                        },
                        {
                          "text": "Other (Specify)",
                          "language": "BCL"
                        },
                        {
