  - name: HOUSEHOLDSURVEY_DICT.Q107_OTHER_ACTIONS_O01
    conditions:
      - questionText:
          EN: |
            <p>107. Did you or your household members do any other actions to improve your/their health condition or address your/their health concern? — Visited other healthcare facility</p>
          BCL: |
            <p>Nagpunta sa iba na healthcare facility</p>
          BIS: |
            <p>Niadto sa lain nga healthcare facility</p>
          CEB: |
            <p>Mibisita sa laing pasilidad sa panglawas</p>
          WAR: |
