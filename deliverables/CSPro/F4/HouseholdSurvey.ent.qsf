  - name: HOUSEHOLDSURVEY_DICT.AREA_HAS_GAMOT
    conditions:
      - questionText:
          EN: |
            <p>Does this area have a Guaranteed and Accessible Medications for Outpatient Treatment (GAMOT) pharmacy/package? (Q69-Q76 apply only to areas with GAMOT.)</p>
          FIL: |
            <p>Does this area have a Guaranteed and Accessible Medications for Outpatient Treatment (GAMOT) pharmacy/package? (Q69-Q76 apply only to areas with GAMOT.)</p>
          BCL: |
            <p>Does this area have a Guaranteed and Accessible Medications for Outpatient Treatment (GAMOT) pharmacy/package? (Q69-Q76 apply only to areas with GAMOT.)</p>
          BIS: |
