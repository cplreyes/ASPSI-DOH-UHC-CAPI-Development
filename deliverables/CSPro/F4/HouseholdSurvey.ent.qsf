    conditions:
      - questionText:
          EN: |
            <p>196. If your household chooses not to spend on health care for financial reasons, what kind of care do you usually forego? — Other (please specify)</p>
          BCL: |
            <p>196. If your household chooses not to spend on health care for financial reasons, what kind of care do you usually forego? — Other (please specify)</p>
          BIS: |
