    conditions:
      - questionText:
          EN: |
            <p>67. How much time does it take for you to reach the nearest pharmacy from your home? (HHMM)</p>
          BCL: |
            <p>Nagaabot pirang oras an pinakaharaning pharmacy saindo?</p>
