  protect(Q157_FOOD_SUBTOTAL_TOTAL_PHP, true);
postproc
  if Q144_CEREALS_CONSUMED = 2 then
    Q144_CEREALS_PURCHASED_PHP = 0;   { item not consumed -> no spend }
    protect(Q144_CEREALS_PURCHASED_PHP, true);
    Q144_CEREALS_INKIND_PHP = 0;   { item not consumed -> no spend }
    protect(Q144_CEREALS_INKIND_PHP, true);
  else
    protect(Q144_CEREALS_PURCHASED_PHP, false);   { enterable when consumed }
    protect(Q144_CEREALS_INKIND_PHP, false);   { enterable when consumed }
  endif;

