# Claude Code local config and automation scripts (settings.local.json holds secrets).
# Whole tree ignored EXCEPT the secret-free scrum-automation scripts whitelisted below.
# settings.local.json and post-daily-standup.ps1 (hardcoded Slack webhook) stay ignored.
.claude/*
!.claude/scripts/
!.claude/hooks/
.claude/scripts/*
.claude/hooks/*
!.claude/scripts/daily-standup-md.ps1
!.claude/scripts/generate_standup.py
!.claude/scripts/generate_retro.py
!.claude/hooks/session-start-scrum.sh
# Nested .claude/ dirs in subprojects (e.g. the F2 PWA app) — local config, keep ignored.
# (The root-anchored .claude/* above no longer catches these, so match them explicitly.)
deliverables/**/.claude/

